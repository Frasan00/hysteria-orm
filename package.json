{
  "name": "hysteria-orm",
  "version": "10.9.8",
  "license": "MIT",
  "description": "Yet another orm for Javascript and Typescript no one asked for",
  "type": "module",
  "homepage": "https://github.com/Frasan00/hysteria-orm",
  "repository": "https://github.com/Frasan00/hysteria-orm.git",
  "author": "Frasan00 <francesco.sangiovanni.7@gmail.com>",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "yarn format && yarn build:dev && node lib/index.js",
    "prepare": "husky install",
    "migrate": "node ./test/migration_runner.js",
    "test": "reset && node ./test/test_runner.js",
    "test:with:migrations": "rm -rf sqlite.db && touch sqlite.db && yarn format && yarn build:prod && yarn migrate && node ./test/test_runner.js",
    "format": "prettier --write \"**/*.ts\"",
    "build": "yarn build:prod",
    "build:prod": "yarn generate:interpreter:map && tsup --minify",
    "build:dev": "tsup",
    "test:fresh": "node lib/cli.js refresh",
    "generate:interpreter:map": "node generate_interpreter_map.js",
    "generate:migrations": "yarn build && node lib/cli.js generate:migrations -d database/index.ts",
    "run:migrations": "yarn build && node lib/cli.js migrate -d database/index.ts",
    "refresh:migrations": "yarn build && node lib/cli.js refresh -d database/index.ts",
    "benchmark": "tsx benchmark/run.ts",
    "benchmark:pg": "tsx benchmark/run.ts --dialect pg",
    "benchmark:mysql": "tsx benchmark/run.ts --dialect mysql",
    "benchmark:setup:pg": "prisma generate --schema benchmark/prisma/pg.prisma",
    "benchmark:setup:mysql": "prisma generate --schema benchmark/prisma/mysql.prisma",
    "benchmark:setup": "yarn benchmark:setup:pg && yarn benchmark:setup:mysql"
  },
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    }
  },
  "bin": {
    "hysteria": "lib/cli.js"
  },
  "files": [
    "lib/**"
  ],
  "devDependencies": {
    "@adminjs/express": "^6.1.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@faker-js/faker": "^9.9.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/mongodb": "^4.0.7",
    "@types/mssql": "^9.1.11",
    "@types/mysql2": "github:types/mysql2",
    "@types/oracledb": "^6.10.2",
    "@types/pg": "^8.20.0",
    "@types/pg-query-stream": "^3.4.0",
    "@types/pino": "^7.0.5",
    "@types/sqlite3": "^5.1.0",
    "adminjs": "^7.8.17",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-formidable": "^1.2.0",
    "express-session": "^1.19.0",
    "husky": "^9.1.7",
    "ioredis": "^5.10.1",
    "jest": "^30.2.0",
    "luxon": "^3.7.2",
    "mongodb": "^7.1.1",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "pg-query-stream": "^4.14.0",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "standard": "^17.1.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.28",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "sql-formatter": "^15.7.3",
    "sql-highlight": "^6.1.0"
  },
  "peerDependencies": {
    "esbuild": "^0.28.0",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.1",
    "oracledb": "^6.10.0",
    "mssql": "^12.2.1",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.2"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "oracledb": {
      "optional": true
    },
    "mssql": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "keywords": [
    "orm",
    "library",
    "sql",
    "SQL",
    "NoSql"
  ]
}
